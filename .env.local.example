# Google Sheets API — Service Account credentials
# Copy this file to .env.local and fill with real values.
# See README.md for step-by-step setup.

# Email of the Service Account (xxx@project.iam.gserviceaccount.com)
GOOGLE_SERVICE_ACCOUNT_EMAIL=

# Private key from the JSON file. Keep the literal \n sequences — they're parsed in lib/sheets.ts.
# Wrap in double quotes so the multi-line key survives shell parsing.
GOOGLE_PRIVATE_KEY=""

# Spreadsheet ID — the long alphanumeric string in the Sheet URL:
# https://docs.google.com/spreadsheets/d/<THIS_PART>/edit
GOOGLE_SHEET_ID=

# Public site URL (used for canonical/Open Graph). Leave blank locally; set in Vercel for production.
NEXT_PUBLIC_SITE_URL=
